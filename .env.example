# ── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/hotel_db"

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="8h"

# ── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Sync (Cloud) ─────────────────────────────────────────
CLOUD_SYNC_URL="https://your-cloud-api.com/sync"
CLOUD_SYNC_SECRET="your-sync-secret"
SYNC_ENABLED=false

# ── Hotel Info ───────────────────────────────────────────
HOTEL_NAME="My Hotel"
HOTEL_ID="hotel-001"